# Google Sheets integration
# 1. Create a Google Cloud project + service account
# 2. Enable Google Sheets API
# 3. Download the service account JSON key
# 4. Share the target Spreadsheet with the service account email (Editor access)

GOOGLE_SHEETS_ID=your-spreadsheet-id-here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Sheet tab name (default: Codes)
GOOGLE_SHEETS_TAB=Codes

# Public base URL where QR codes will point (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Brand
NEXT_PUBLIC_BRAND_NAME=BinKis
NEXT_PUBLIC_COLLECTION_NUMBER=777
