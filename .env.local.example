# ============================================================================
# Supabase (production database)
# Get these from: Supabase Dashboard -> Project Settings -> API
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# ============================================================================
# Admin gate (password protects /, /generate, /codes, /winners, /lottery, etc.)
# ============================================================================
ADMIN_PASSWORD=change-this-to-a-strong-password

# ============================================================================
# Brand + base URL
# ============================================================================
NEXT_PUBLIC_BASE_URL=https://binkis.xyz
NEXT_PUBLIC_BRAND_NAME=BinKis
NEXT_PUBLIC_COLLECTION_NUMBER=777

# ============================================================================
# OPTIONAL: Google OAuth Client ID for "Sign in with Google" in subscribe modal
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized JS origins should include http://localhost:3002 and your Vercel URL
# ============================================================================
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ============================================================================
# LEGACY: Google Sheets credentials (only needed if running migrate-sheets script)
# Safe to remove after migration is complete.
# ============================================================================
GOOGLE_SHEETS_ID=your-spreadsheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_TAB=Codes
